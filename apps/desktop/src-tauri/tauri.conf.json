{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "insta-review",
  "version": "0.1.0",
  "identifier": "dev.instareview.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "review",
        "title": "insta-review",
        "width": 1440,
        "height": 900,
        "visible": false,
        "resizable": true,
        "backgroundColor": "#101014"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
